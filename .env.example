# Copy this file to .env and edit the paths for your system.
#   cp .env.example .env
# .env is gitignored — your personal paths stay out of the repo.

# ── Host directories mounted into the container ───────────────────────────────
# Your music library (beets moves imported files here, read-write).
QL_MUSIC_DIR=./music

# Scratch space for in-progress streamrip downloads.
QL_STAGING_DIR=./staging

# Where pre-upgrade backups are kept before a quality upgrade replaces files.
QL_UPGRADE_BACKUPS=./upgrade_backups

# Library migration (optional — only for the one-time Migrate tool). The messy
# library to read and a separate, empty folder to build the organised copy
# into; mount both, then set them here. Leave unset if you're not migrating.
# QL_MIGRATE_SRC=/old-library
# QL_MIGRATE_DEST=/organised

# ── Web UI ────────────────────────────────────────────────────────────────────
# Host port the web UI is published on.
WEB_PORT=8666

# Login. Leave this unset (or anything other than "none") and the web UI asks
# you to pick a username and password on first visit, then requires sign-in.
# Set WEB_AUTH=none to turn the login off entirely — no setup screen, no
# prompt. Only do that on a trusted network or behind your own authenticating
# reverse proxy; an unauthenticated UI is a download/delete button for anyone
# who can reach the port.
# WEB_AUTH=none

# Optionally set the login here instead of on the first-visit setup screen.
# Provide both: the container comes up already locked down (no open setup
# window) and these double as a password reset — change them and restart to
# update the login. They're only read when both are set; once a login exists,
# the same pair is left alone unless the password here changes. Pick a strong
# password (at least 8 characters — the same minimum the setup screen enforces;
# a shorter one is accepted but warns in the log), and note an env value is
# visible to anyone who can inspect the container (you can clear these after
# first start; the login persists).
# WEB_AUTH_USER=admin
# WEB_AUTH_PASSWORD=change-me-to-something-strong

# Behind a reverse proxy? Set this to the proxy's IP (or a comma-separated
# list) so the app trusts its X-Forwarded-For and the failed-login throttle
# keys on the real client instead of locking everyone out behind one shared
# proxy address. Leave unset (defaults to 127.0.0.1) when the container is
# reached directly. Don't set it to "*" unless the container is ONLY reachable
# through a proxy that overwrites X-Forwarded-For — otherwise the header is
# spoofable and the throttle is defeated.
# FORWARDED_ALLOW_IPS=172.18.0.1

# Terminal-first mode (optional). The web app and CLI share one download lock,
# so they take turns. Set this to 1 to always start handed-off to the terminal:
# `docker exec ... qobuz-librarian` works immediately and the web UI's downloads
# stay paused (you can still browse + use Settings, and resume web mode there).
# Leave unset to default to the web app. To hand off case-by-case instead, use
# Settings → Mode in the web UI.
# QL_CLI_ONLY=1

# ── User / permissions ────────────────────────────────────────────────────────
# The app runs as this uid/gid (default 1000:1000) so downloaded files match
# you, not root. Find your values with `id -u` and `id -g` on the host and set
# them here if they aren't 1000 — they flow straight into the container, no
# need to edit compose.yaml. PUID=0 / PGID=0 runs as root if you really need it.
# PUID=1000
# PGID=1000

# ── Qobuz auth (optional) ─────────────────────────────────────────────────────
# Easiest to set these from the Settings page in the web UI instead — leave
# them commented here and the dashboard will prompt you on first run.
# The token is streamrip's `password_or_token` (NOT your password): get it
# from play.qobuz.com — dev tools (F12) → Application → Local Storage →
# play.qobuz.com → the `localuser` entry's `token`. USER_ID is
# your account email or numeric Qobuz user id. Setting them here pins them
# (the Settings page can't override an env-provided token until it's unset).
# QOBUZ_USER_AUTH_TOKEN=your_token_here
# QOBUZ_USER_ID=your_user_id_here
# Or keep the token out of the environment entirely and read it from a file
# (e.g. a Docker secret) — set this instead of QOBUZ_USER_AUTH_TOKEN:
# QOBUZ_USER_AUTH_TOKEN_FILE=/run/secrets/qobuz_token

# ── Behaviour overrides (optional) ────────────────────────────────────────────
# Every setting on the web UI's Settings page is also an env var — pin a value
# here to override the Settings file and survive a container rebuild. Defaults
# shown; uncomment what you want to lock in.
#
# Quality tier: 1=320kbps · 2=CD lossless · 3=24/96 · 4=24/192
# STREAMRIP_QUALITY=4
# PREFER_HIRES=1
# CONSOLIDATE=0
# These two change files. DOWNSAMPLE_HIRES_ENABLED shrinks NEW hi-res downloads
# to CD rate on import; to shrink hi-res already in your library, use the
# on-demand Downsample page/mode instead (no setting needed).
# AUTO_UPGRADE_ENABLED=0
# DOWNSAMPLE_HIRES_ENABLED=0
#
# New releases: auto-scan the library on first launch (off skips it), and how
# often (seconds) to auto-check for new releases afterwards (0 = off).
# AUTO_LIBRARY_SCAN=1
# NEW_RELEASE_CHECK_INTERVAL=86400
#
# Lyrics: embed | sidecar | both. Providers: Lrclib, NetEase, Musixmatch.
# LYRICS_ENABLED=1
# LYRICS_FORMAT=embed
# LYRICS_PROVIDERS=Lrclib,NetEase,Musixmatch
#
# Cover art placement: sidecar (image beside the tracks) | embed | both.
# ARTWORK=sidecar
#
# beets path templates (empty = honour beets/config.yaml). beets path syntax.
# BEETS_PATH_DEFAULT=$albumartist/$album ($year)/$track - $title
# BEETS_PATH_SINGLETON=$albumartist/$album ($year)/$track - $title
# BEETS_PATH_COMP=Various Artists/$album ($year)/$track - $title
# BEETS_PLUGINS=fetchart,lastgenre,replaygain
#
# beets import guard — how long a stalled import may hang before it's killed
# and the album quarantined for retry, how many attempts, and the pause
# between them. Worth raising the timeout on a slow NAS.
# BEETS_TIMEOUT=600
# BEETS_MAX_ATTEMPTS=2
# BEETS_RETRY_PAUSE=30
#
# Polite-API knobs — only worth touching if you're being rate-limited.
# RATE_LIMIT_COOLDOWN=30
# ARTIST_API_DELAY=0.4
# UPGRADE_BACKUP_RETENTION_DAYS=7
#
# Run a command when a job finishes (download / scan / upgrade / …) with the
# job's final state as JSON on stdin — wire up a phone/desktop notification or
# your own automation. Unset = nothing runs; the timeout caps a slow webhook.
# POST_JOB_HOOK=/config/notify.sh
# POST_JOB_HOOK_TIMEOUT=10
#
# Parallel ffmpeg workers for the on-demand downsample (CPU-bound).
# RESAMPLE_WORKERS=4
#
# Log verbosity: DEBUG | INFO | WARNING | ERROR.
# LOG_LEVEL=INFO
#
# Web UI per-request budgets (seconds). Bump if your Qobuz API calls
# routinely time out; drop if you'd rather fail fast on a slow network.
# QL_WEB_FETCH_TIMEOUT bounds album fetches and the search box.
# QL_WEB_TEST_AUTH_TIMEOUT bounds the startup + Settings token probe.
# QL_WEB_FETCH_TIMEOUT=12.0
# QL_WEB_TEST_AUTH_TIMEOUT=8.0
